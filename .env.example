# Example environment variables for local development
# Copy this file to .env.local and fill in your real values.
# Do NOT commit real keys to the repo. Use Vercel dashboard for production.

VITE_OPENAI_KEY=your_openai_api_key_here
VITE_STABILITY_KEY=your_stability_ai_key_here

# Optional: other keys the app needs
# VITE_SUPABASE_URL=https://your-supabase-url
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
